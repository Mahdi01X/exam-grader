# --- API & sécurité ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# --- Base de données ---
POSTGRES_USER=examgrader
POSTGRES_PASSWORD=examgrader
POSTGRES_DB=examgrader
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://examgrader:examgrader@db:5432/examgrader

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=4096
# temperature basse pour reproductibilité
ANTHROPIC_TEMPERATURE=0.0

# --- Stockage ---
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=/data/uploads
# Pour S3 plus tard:
# STORAGE_BACKEND=s3
# S3_BUCKET=...
# S3_REGION=...

# --- Pipeline ---
PDF_RENDER_DPI=300
CONFIDENCE_REVIEW_THRESHOLD=0.80
MAX_UPLOAD_MB=50

# --- Admin bootstrap ---
BOOTSTRAP_ADMIN_EMAIL=admin@local
